{
  "openapi": "3.1.0",
  "info": {
    "title": "Milo API",
    "description": "The Milo API allows you to extract structured data from CRE documents.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.runmilo.ai/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/extract": {
      "post": {
        "operationId": "extract",
        "summary": "Extract structured data",
        "description": "Upload all CRE documents, including  property info, financials, and rent stack data to receive structured extraction results.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["files"],
                "properties": {
                  "files": {
                    "type": "array",
                    "description": "One or more files to extract data from. Supported formats include PDF, XLSX, CSV, DOCX, and images (PNG, JPG).",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extraction completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractionResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExtractionResult": {
        "type": "object",
        "required": ["deal_id", "status"],
        "properties": {
          "deal_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the deal"
          },
          "status": {
            "type": "string",
            "description": "Status of the extraction",
            "enum": ["pending", "processing", "completed", "failed"]
          },
          "property": {
            "$ref": "#/components/schemas/ExtractionPropertyInfo"
          },
          "financials": {
            "$ref": "#/components/schemas/ExtractionFinancials"
          },
          "rent_stack": {
            "type": "array",
            "description": "Unit-level rent data",
            "items": {
              "$ref": "#/components/schemas/ExtractionRentStackItem"
            }
          },
          "documents": {
            "type": "array",
            "description": "Metadata for each uploaded document",
            "items": {
              "$ref": "#/components/schemas/ExtractionDocumentInfo"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of when the extraction was created",
            "nullable": true
          }
        }
      },
      "ExtractionPropertyInfo": {
        "type": "object",
        "description": "Extracted property details",
        "properties": {
          "property_name": {
            "type": "string",
            "nullable": true,
            "description": "Name of the property"
          },
          "property_address": {
            "type": "string",
            "nullable": true,
            "description": "Street address of the property"
          },
          "purchase_price": {
            "type": "number",
            "nullable": true,
            "description": "Purchase price of the property"
          },
          "year_built": {
            "type": "integer",
            "nullable": true,
            "description": "Year the property was built"
          },
          "units": {
            "type": "integer",
            "nullable": true,
            "description": "Total number of units"
          }
        }
      },
      "ExtractionFinancials": {
        "type": "object",
        "description": "Extracted financial data",
        "properties": {
          "vacancy_rate": {
            "type": "number",
            "nullable": true,
            "description": "Vacancy rate as a decimal (e.g. 0.05 for 5%)"
          },
          "current_average_rent": {
            "type": "number",
            "nullable": true,
            "description": "Current average rent per unit"
          },
          "manual_proven_rent": {
            "type": "number",
            "nullable": true,
            "description": "Manual proven rent"
          },
          "mapped_income": {
            "type": "array",
            "nullable": true,
            "description": "Income line items extracted from the T12",
            "items": {
              "$ref": "#/components/schemas/FinancialNode"
            }
          },
          "mapped_expenses": {
            "type": "array",
            "nullable": true,
            "description": "Expense line items extracted from the T12",
            "items": {
              "$ref": "#/components/schemas/FinancialNode"
            }
          }
        }
      },
      "FinancialNode": {
        "type": "object",
        "description": "A single financial line item extracted from the T12",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Row index from the source document"
          },
          "field": {
            "type": "string",
            "description": "Category slug (e.g. 'gross_potential_rent', 'operating_expense')"
          },
          "display_name": {
            "type": "string",
            "description": "Original label from the source document"
          },
          "value": {
            "type": "string",
            "description": "Dollar amount as a string (e.g. '864000.00')"
          },
          "citation": {
            "type": "string",
            "description": "Source reference (e.g. 'row:5')"
          },
          "user_adjusted": {
            "type": "boolean",
            "description": "Whether this value has been manually adjusted"
          },
          "source_items": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Row indices of child line items (for subtotal rows)"
          }
        }
      },
      "ExtractionRentStackItem": {
        "type": "object",
        "description": "A single row in the rent stack",
        "properties": {
          "unit_type": {
            "type": "string",
            "nullable": true,
            "description": "Unit type (e.g. 1BR, 2BR, Studio)"
          },
          "unit_count": {
            "type": "integer",
            "nullable": true,
            "description": "Number of units of this type"
          },
          "sq_ft": {
            "type": "integer",
            "nullable": true,
            "description": "Square footage per unit"
          },
          "current_rent": {
            "type": "number",
            "nullable": true,
            "description": "Current monthly rent"
          },
          "market_rent": {
            "type": "number",
            "nullable": true,
            "description": "Market rent"
          },
          "projected_rent": {
            "type": "number",
            "nullable": true,
            "description": "Projected rent after renovation or lease-up"
          }
        }
      },
      "ExtractionDocumentInfo": {
        "type": "object",
        "description": "Metadata about an uploaded document",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique document identifier"
          },
          "file_name": {
            "type": "string",
            "nullable": true,
            "description": "Original file name"
          },
          "document_type": {
            "type": "string",
            "nullable": true,
            "description": "Detected document type (e.g. rent_roll, operating_statement, offering_memorandum)"
          },
          "extraction_status": {
            "type": "string",
            "nullable": true,
            "description": "Extraction status for this document",
            "enum": ["pending", "processing", "completed", "failed"]
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
