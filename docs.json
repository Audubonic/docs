{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Milo Docs",
  "colors": {
    "primary": "#7C5CFC",
    "light": "#7C5CFC",
    "dark": "#ceb7e2"
  },
  "favicon": "/favicon.png",
  "background": {
    "color": {
      "light": "#FAF9F5",
      "dark": "#262624"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart/index",
              "using-milo/suggested-documents"
            ]
          },
          {
            "group": "CRE Glossary",
            "pages": [
              "glossary/income-and-revenue",
              "glossary/expenses",
              "glossary/net-operating-income",
              "glossary/return-metrics",
              "glossary/debt-and-leverage",
              "glossary/valuation-and-pricing",
              "glossary/cash-flow",
              "glossary/assumptions",
              "glossary/deal-structure",
              "glossary/document-types"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/extract"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@audubonic.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://runmilo.ai"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "search": {
    "ai": true
  },
  "chat": {
    "enabled": true
  },
  "layout": {
    "toc": false
  },
  "metadata": {
    "og:site_name": "Milo Developer Docs",
    "og:title": "Milo Developer Docs - Milo Developer Documentation",
    "og:description": "Official developer documentation for Milo. Get started with guides, API references, and integrations.",
    "og:image": "/milo-share.png",
    "twitter:card": "summary_large_image",
    "twitter:image": "/milo-share.png",
    "timestamp": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usemiloai",
      "linkedin": "https://www.linkedin.com/company/runmiloai",
      "website": "https://runmilo.io"
    }
  },
  "thumbnails": {
    "appearance": "light",
    "background": "/milo-share.png"
  },
  "fonts": {
    "family": "Inter"
  },
  "description": "Official documentation for Milo. Get started with guides, API references, and integrations.",
  "openapi": [
    "api-reference/openapi.json"
  ]
}
